---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';

import { headerData } from '~/navigation';
import FAQs from '~/components/widgets/FAQs.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

const metadata = {
  title: ' Gamya.xyz | Staking Platform Services Trusted by Institutions',
};
---

<Layout metadata={metadata}>
  <script type='text/javascript' src='https://platform-api.sharethis.com/js/sharethis.js#property=69a47af3200264b38d859e1e&product=sop' async='async'></script>
  <Fragment slot="header">
    <Header
      {...headerData}
      actions={[
        {
          variant: 'secondary',
          text: 'BUY TANGEM',
          href: 'https://tangem.com/invite/EW8JGT',
        },
        {
          variant: 'primary',
          text: 'From $ 54.90',
          href: 'https://tangem.com/invite/EW8JGT',
        },
      ]}
      isSticky
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline=""
    actions={[
      { variant: 'primary', target: '', text: 'From $ 54.90', href: 'https://tangem.com/invite/EW8JGT' },
      { text: 'BUY TANGEM', href: 'https://tangem.com/invite/EW8JGT' },
       { text: 'EXCHANGE', href: '/home/exchange' },
    ]}
    image={{
      src: 'https://image2url.com/r2/default/images/1774823955489-d9c39084-c73b-43c3-a52d-580bfeccc7f5.png',
      alt: 'AstroWind Hero Image',
    }}
  >
    <Fragment slot="title">
      
      Tangem <br /> Your <span class="text-accent dark:text-white">Crypto</span> - Wallet<br
      />
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
       <script crossOrigin="anonymous" async src="https://static.coinstats.app/widgets/coin-list-widget.js"></script>
<coin-stats-list-widget locale="en" currency="USD" bg-color="#040422" status-up-color="#74D492" status-down-color="#FE4747" text-color="#FFFFFF" font="Outfit, Arial, Helvetica" border-color="rgba(255,255,255,0.15)" width="100%" top-coin="8"></coin-stats-list-widget>
    </Fragment>
  </Hero2>

  <!-- Features Widget *************** -->

  <Features
    id="features"
    title="Crypto & Hardware Wallet"
    subtitle="Slim as a bank card, secure as a bank vault. Store, buy, earn, transfer and swap thousands of coins and tokens."
    columns={2}
    items={[
      {
        title: 'The highest chip security standard.',
        description:
          'Protection from any invasive and non-invasive attacks.',
        icon: 'tabler:layers-union',
      },
      {
        title: 'Maximum resistance',
        description: `to dust, water and extreme temperatures.`,
        icon: 'tabler:artboard',
      },
      {
        title: 'Hazard protection.',
        description:
          'Resistant to X-rays, electromagnetic pulses, and electrostatic discharge.',
           icon: 'tabler:writing',
      },
      {
        title: 'Counterfeit protection.',
        description: `The Tangem app verifies the authenticity of the chip and firmware.`,
        icon: 'tabler:podium',
      },
      
    ]}
  />

  

  <script>
  (function(){var w=window;if(w.ChannelIO){return w.console.error("ChannelIO script included twice.");}var ch=function(){ch.c(arguments);};ch.q=[];ch.c=function(args){ch.q.push(args);};w.ChannelIO=ch;function l(){if(w.ChannelIOInitialized){return;}w.ChannelIOInitialized=true;var s=document.createElement("script");s.type="text/javascript";s.async=true;s.src="https://cdn.channel.io/plugin/ch-plugin-web.js";var x=document.getElementsByTagName("script")[0];if(x.parentNode){x.parentNode.insertBefore(s,x);}}if(document.readyState==="complete"){l();}else{w.addEventListener("DOMContentLoaded",l);w.addEventListener("load",l);}})();

  ChannelIO('boot', {
    "pluginKey": "4ab7df9e-18f3-42ef-94c8-2fae15dbe5cd"
  });
</script>
</Layout>
