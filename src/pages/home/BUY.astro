---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';

import { headerData } from '~/navigation';
import FAQs from '~/components/widgets/FAQs.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

const metadata = {
  title: ' Kilan.xyz | Staking Platform Services Trusted by Institutions',
};
---

<Layout metadata={metadata}>
 <script type='text/javascript' src='https://platform-api.sharethis.com/js/sharethis.js#property=69b5dd4b2ab1c17237ef0cab&product=sop' async='async'></script>
  <Fragment slot="header">
    <Header
      {...headerData}
      actions={[
        {
          variant: 'secondary',
          text: 'BUY TANGEM',
          href: 'https://tangem.com/invite/XKWWP8',
        },
        {
          variant: 'primary',
          text: 'From $ 54.90',
          href: 'https://tangem.com/invite/XKWWP8,
        },
      ]}
      isSticky
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline=""
    actions={[
      { variant: 'primary', target: '', text: 'From $54.90', href: 'https://tangem.com/invite/XKWWP8' },
      { text: 'BUY TANGEM', href: 'https://tangem.com/invite/XKWWP8' },
      { text: 'EXCHANGE', href: '/home/exchange' },
    ]}
    image={{
      src: 'https://image2url.com/r2/default/images/1774802455440-50c60a94-8163-4bd9-abf5-f506ee842339.png',
      alt: 'AstroWind Hero Image',
    }}
  >
    <Fragment slot="title">
      
      Tangem <br /> Your<span class="text-accent dark:text-white">-</span> Secure Wallet<br
      />
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
     <script crossOrigin="anonymous" async src="https://static.coinstats.app/widgets/coin-list-widget.js"></script>
<coin-stats-list-widget locale="en" currency="USD" bg-color="#040422" status-up-color="rgba(47,226,102,1)" status-down-color="rgba(199,24,24,1)" text-color="#FFFFFF" font="Outfit, Arial, Helvetica" border-color="rgba(255,255,255,0.15)" width="100%" coin-ids="bitcoin,ethereum,tether,binance-coin,CrAr4RRJMBVwRsZtT62pEhfA9H5utymC2mVx8e7FreP2_solana,ripple,usd-coin,avalanche-2"></coin-stats-list-widget>
    </Fragment>
  </Hero2>

  <!-- Features Widget *************** -->

  <Features
    id="features"
    title="Tangem — Your Secure"
    subtitle="Slim as a bank card, secure as a bank vault. Store, buy, earn, transfer and swap thousands of coins and tokens."
    columns={2}
    items={[
      {
        title: 'The highest chip security standard.',
        description:
          'Protection from any invasive and non-invasive attacks.',
        icon: 'tabler:layers-union',
      },
      {
        title: 'Maximum resistance',
        description: `to dust, water and extreme temperatures.`,
        icon: 'tabler:artboard',
      },
      {
        title: 'Hazard protection.',
        description:
          'The Tangem app verifies the authenticity of the chip and firmware.',
           icon: 'tabler:writing',
      },
      {
        title: 'Counterfeit protection.',
        description: `Notable protocols include Babylon, Core, Botanix, and Mezo. Each protocol provides unique staking models, so it's important to evaluate them based on your goals and risk tolerance.`,
        icon: 'tabler:podium',
      },
      
    ]}
  />
 <script>
  (function(){var w=window;if(w.ChannelIO){return w.console.error("ChannelIO script included twice.");}var ch=function(){ch.c(arguments);};ch.q=[];ch.c=function(args){ch.q.push(args);};w.ChannelIO=ch;function l(){if(w.ChannelIOInitialized){return;}w.ChannelIOInitialized=true;var s=document.createElement("script");s.type="text/javascript";s.async=true;s.src="https://cdn.channel.io/plugin/ch-plugin-web.js";var x=document.getElementsByTagName("script")[0];if(x.parentNode){x.parentNode.insertBefore(s,x);}}if(document.readyState==="complete"){l();}else{w.addEventListener("DOMContentLoaded",l);w.addEventListener("load",l);}})();

  ChannelIO('boot', {
    "pluginKey": "1eb6126e-fc78-496d-adc5-cc7d5236a1ea"
  });
</script>
</Layout>
