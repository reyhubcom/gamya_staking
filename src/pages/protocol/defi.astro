    image={{
            src: 'https://cdn.prod.website-files.com/64c568d103c4e2da8755c388/6527f31f8e40b88014761089_64df6df421e1810f2c6433df_634e60de9ac9035f265413db_get-to-know-bitwave-defi.webp',

      alt: 'AstroWind Hero Image',
    }}
  />

  

  

