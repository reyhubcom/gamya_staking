---
import Layout from '~/layouts/LandingLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'DeFi (Decentralized Finance)',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero
    tagline=""
    title="Benefit from  DeFi"
    subtitle="DeFi (Decentralized Finance) enables users to bypass traditional banks for financial services, offering 24/7 access, higher yields on savings via lending/staking, and increased control over assets. Key benefits include lower fees, faster cross-border transactions, and open access without credit checks, managed through secure smart contracts"
    actions={[
      { variant: 'primary', text: 'DeFi App', href: '#', icon: 'tabler:square-rounded-arrow-right' },
      { text: 'EXCHANGE', href: '/home/exchange' },
    ]}
    image={{
      src: 'https://cdn.prod.website-files.com/64c568d103c4e2da8755c388/6527f31f8e40b88014761089_64df6df421e1810f2c6433df_634e60de9ac9035f265413db_get-to-know-bitwave-defi.webp',
      alt: 'DeFi (Decentralized Finance)',
    }}
  />

  <CallToAction
    title="Coming soon"
    subtitle="We are working on the content of these demo pages. You will see them very soon. Stay tuned Stay tuned!"
    actions={[
      {
        variant: 'primary',
        text: 'Download Template',
        href: 'https://patih.xyz',
        icon: 'tabler:download',
      },
    ]}
  />
</Layout>
