---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Services',
};
---

<Layout metadata={metadata}>
 <script type='text/javascript' src='https://platform-api.sharethis.com/js/sharethis.js#property=69a47af3200264b38d859e1e&product=sop' async='async'></script>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline=""
    title="Ethereum Reward"
    subtitle="Ethereum staking rewards currently offer an estimated annual yield of approximately 1.91% to over 5% (with higher, variable rates around 2.85%–5.65% often reported) for validating network transactions. Rewards are earned through consensus participation (attestations) and transaction fees, with higher payouts for consistent validator uptime."
    actions={[{ variant: 'primary', target: '', text: 'REWARD APP', href: '/home/exchange' }]}
    image={{
            src: 'https://cdn.prod.website-files.com/633c67ced5457aa4dec572be/6446b251633c937b449d16db_Ethereum%20News%20by%20Blockdaemon.jpg',

      alt: 'AstroWind Hero Image',
    }}
  />

  

  

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="Typically Rewards Range Between 1.9% and 5.7% APY,"
    testimonials={[
      {
        testimonial: `Ether.fi (ETHFI) is a decentralized, non-custodial liquid restaking protocol built on the Ethereum blockchain. It allows users to stake assets like Ethereum (ETH) to earn rewards while maintaining full control over their private keys.`,
        name: 'Ether.Fi',
        job: 'Save, Grow, Spend.',
        image: {
          src: 'https://miro.medium.com/v2/resize:fit:400/1*REBCWJIqtTqpPIvjve1aOg.jpeg',
          alt: 'Ether Fi Image',
        },
      },
      {
        testimonial: `Stake DAO is a non-custodial decentralized asset management platform built primarily on Ethereum that allows users to grow, track, and control their crypto assets through a single dashboard. It is designed to optimize yield and governance for users who hold "vote-escrowed" (ve) tokens.`,
        name: 'Stake DAO',
        job: 'Ethereum Rewards',
        image: {
          src: 'https://raw.githubusercontent.com/stake-dao/assets/refs/heads/main/assets/archive/sdt.svg',
          alt: 'Sarah Hansen Image',
        },
      },
      {
        testimonial: `Kelp DAO is a decentralized liquid restaking protocol on Ethereum and EigenLayer that helps users maximize staking rewards. It enables users to deposit liquid staking tokens (like stETH) to receive rsETH, a liquid, yield-bearing token that maintains liquidity while earning additional restaking rewards.`,
        name: 'Kelp DAO',
        job: 'Boost your rewards on ETH,',
        image: {
          src: 'https://pbs.twimg.com/profile_images/2026633020942499840/7aPfbguV_400x400.jpg',
          alt: 'Sarah Hansen Image',
        },
      },
      {
        testimonial: `Kelp DAO is a decentralized liquid restaking protocol on Ethereum and EigenLayer that helps users maximize staking rewards. It enables users to deposit liquid staking tokens (like stETH) to receive rsETH, a liquid, yield-bearing token that maintains liquidity while earning additional restaking rewards.`,
        name: 'Vestra DAO',
        job: 'Boost your rewards on ETH,',
        image: {
          src: 'https://jid.rerrkvifj.com/exchangeBm-upload/img/seo/SEO_vestra-dao.png',
          alt: 'Sarah Hansen Image',
        },
      },
      {
        testimonial: `‍Fluid is a decentralized finance (DeFi) protocol designed to enhance capital efficiency and user experience in lending and borrowing. The lending protocol allows users to supply assets and receive rewards in kind while the Vault Protocol provides advanced borrowing capabilities with high loan-to-value (LTV) ratios and minimal liquidation penalties. The liquidity protocol serves as a foundational layer, consolidating liquidity across the ecosystem to enable seamless interaction between protocols without requiring each to attract liquidity independently.`,
        name: 'Fluid',
        job: 'Supported EVMs Ethereum, Arbitrum, Base',
        image: {
          src: 'https://zouvpsatdxeb2tch.public.blob.vercel-storage.com/asset-slug-logos/fluid.png',
          alt: 'Sarah Hansen Image',
        },
      },
      {
        testimonial: `Kinetic is an overcollateralized lending platform built on the Flare blockchain, facilitating peer-to-peer borrowing with dynamic interest rates. The protocol requires borrowers to provide collateral exceeding their loan value to maintain system stability. Interest rates are transparently determined by real-time supply and demand, reflecting market conditions for lending and borrowing.`,
        name: 'Kinetic',
        job: 'Supported EVMs Flare',
        image: {
          src: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRXVWdrSAkCg6yaAF6cecD64Cm2AhHNcsrWDA&s',
          alt: 'Mark Wilkinson Image',
        },
      },
    ]}
    callToAction={{
      target: '',
      text: 'More DeFi...',
      href: '/home/exchange',
      icon: 'tabler:chevron-right',
    }}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
  
    actions={[
      {
        variant: 'primary',
        text: 'Start exploring',
        href: '/',
      },
    ]}
    title="Dive into our template collection"
    subtitle="Whether you're in business, design, or education, our templates are here to elevate your projects."
    
  />
  <script>
  (function(){var w=window;if(w.ChannelIO){return w.console.error("ChannelIO script included twice.");}var ch=function(){ch.c(arguments);};ch.q=[];ch.c=function(args){ch.q.push(args);};w.ChannelIO=ch;function l(){if(w.ChannelIOInitialized){return;}w.ChannelIOInitialized=true;var s=document.createElement("script");s.type="text/javascript";s.async=true;s.src="https://cdn.channel.io/plugin/ch-plugin-web.js";var x=document.getElementsByTagName("script")[0];if(x.parentNode){x.parentNode.insertBefore(s,x);}}if(document.readyState==="complete"){l();}else{w.addEventListener("DOMContentLoaded",l);w.addEventListener("load",l);}})();

  ChannelIO('boot', {
    "pluginKey": "4ab7df9e-18f3-42ef-94c8-2fae15dbe5cd"
  });
</script>
</Layout>
